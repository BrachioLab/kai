def cmd_gpus(args):
    r = kubectl("get", "pods", "-o", "json", capture=True)
    pods = json.loads(r.stdout).get("items", [])

    # Count GPU requests for Running/Pending pods per node
    allocated = {}
    for pod in pods:
        phase    = pod.get("status", {}).get("phase", "")
        node     = pod.get("spec", {}).get("nodeName") or "_pending"
        if phase not in ("Running", "Pending"):
            continue
        for c in pod.get("spec", {}).get("containers", []):
            gpus = int(c.get("resources", {}).get("limits", {}).get("nvidia.com/gpu", 0))
            if gpus:
                allocated[node] = allocated.get(node, 0) + gpus

    rows = []
    total_count = total_used = 0
    for node, info in GPU_NODES.items():
        used  = allocated.get(node, 0)
        free  = info["count"] - used
        rows.append((
            node,
            f"{info['name']} ({info['mem_gb']}GB)",
            str(info["count"]),
            str(used),
            str(free),
        ))
        total_count += info["count"]
        total_used  += used

    _print_table(
        ("NODE", "GPU", "TOTAL", "USED", "FREE"),
        rows,
        footer=("TOTAL", "", str(total_count), str(total_used), str(total_count - total_used)),
    )

# ── nodes ──────────────────────────────────────────────────────────────────────

def cmd_nodes(args):
    r = kubectl("get", "nodes", "-o", "json", capture=True)
    nodes = json.loads(r.stdout).get("items", [])

    # GPU allocation across all namespaces
    rp = kubectl("get", "pods", "--all-namespaces", "-o", "json", capture=True)
    pods = json.loads(rp.stdout).get("items", [])
    allocated = {}
    for pod in pods:
        if pod.get("status", {}).get("phase") not in ("Running", "Pending"):
            continue
        node = pod.get("spec", {}).get("nodeName") or ""
        for c in pod.get("spec", {}).get("containers", []):
            gpus = int(c.get("resources", {}).get("limits", {}).get("nvidia.com/gpu", 0))
            if gpus:
                allocated[node] = allocated.get(node, 0) + gpus

    now = datetime.now(timezone.utc)
    rows = []
    for node in nodes:
        name   = node["metadata"]["name"]
        spec   = node.get("spec", {})
        conds  = {c["type"]: c for c in node["status"].get("conditions", [])}

        # Ready status + last heartbeat age
        ready_cond = conds.get("Ready", {})
        ready      = ready_cond.get("status", "Unknown")
        heartbeat  = ready_cond.get("lastHeartbeatTime", "")
        if heartbeat:
            hb_age = _fmt_age(heartbeat)
        else:
            hb_age = "?"

        # Node status string
        if spec.get("unschedulable"):
            status = "Cordoned"
        elif ready != "True":
            status = "NotReady"
        else:
            status = "Ready"

        # Active pressure conditions
        issues = []
        for cond_type in ("DiskPressure", "MemoryPressure", "PIDPressure"):
            if conds.get(cond_type, {}).get("status") == "True":
                issues.append(cond_type)
        issues_str = ", ".join(issues) if issues else "—"

        # GPU info (GPU nodes only)
        gpu_info = GPU_NODES.get(name)
        if gpu_info:
            total = gpu_info["count"]
            used  = allocated.get(name, 0)
            gpu_col = f"{used}/{total}"
        else:
            gpu_col = "—"

        rows.append((name, status, gpu_col, hb_age, issues_str))

    _print_table(("NODE", "STATUS", "GPU (used/total)", "HEARTBEAT", "CONDITIONS"), rows)

