    p.set_defaults(func=cmd_nodes)

    # ── status ──
    p = sub.add_parser("status", help="Show all resources in the namespace")
    p.set_defaults(func=cmd_status)

    # ── add-user ──
    p = sub.add_parser("add-user", help="Add a new user to this lab (creates SA, token, RoleBinding)")
    p.add_argument("--name", required=True, metavar="USERNAME",
                   help="New user's username (must match their OS account)")
    p.add_argument("--role", choices=["researcher", "lab-manager"], default="researcher",
                   help="Role to assign (default: researcher)")
    p.add_argument("--queue", metavar="QUEUE",
                   help="Default queue for this user (default from config)")
    p.set_defaults(func=cmd_add_user)

    # ── push-config ──
    p = sub.add_parser("push-config", help="Push updated CLI config for an existing user (no Kubernetes changes)")
    p.add_argument("--name", metavar="USERNAME", default=None,
                   help="Username to update (default: current OS user)")
    p.add_argument("--role", choices=["researcher", "lab-manager"], default=None,
                   help="Role (default: your own role for self-updates, researcher for others)")
    p.add_argument("--queue", metavar="QUEUE",
                   help="Default queue (default from config)")
    p.set_defaults(func=cmd_push_config)

    # ── setup ──
    p = sub.add_parser("setup", help="Install kubeconfig and CLI config from files")
    p.add_argument("config_file", metavar="CONFIG", nargs="?", default=None,
                   help="Path to kai-config-<user>.yaml (omit to auto-fetch from the configured configs repo)")
    p.add_argument("kubeconfig_file", metavar="KUBECONFIG",
                   help="Path to kai-kubeconfig-<user>.yaml (received via secure channel)")
