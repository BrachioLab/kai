def _fmt_age(ts):
    if not ts:
        return "—"
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        s  = int((datetime.now(timezone.utc) - dt).total_seconds())
        if s < 60:     return f"{s}s"
        if s < 3600:   return f"{s // 60}m"
        if s < 86400:  return f"{s // 3600}h"
        return f"{s // 86400}d"
    except Exception:
        return "—"

def _print_table(headers, rows, footer=None):
    all_rows = [headers] + rows + ([footer] if footer else [])
    col_w    = [max(len(str(r[i])) for r in all_rows) for i in range(len(headers))]
    sep      = "  ".join("─" * w for w in col_w)

    print("  ".join(str(h).ljust(col_w[i]) for i, h in enumerate(headers)))
    print(sep)
    for row in rows:
        print("  ".join(str(v).ljust(col_w[i]) for i, v in enumerate(row)))
    if footer:
        print(sep)
        print("  ".join(str(v).ljust(col_w[i]) for i, v in enumerate(footer)))

def _die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)

# ── argument parser ────────────────────────────────────────────────────────────

def main():
    global KUBECONFIG, NAMESPACE

    # Load config file first (CLI flags override below)
    _load_config()

    parser = argparse.ArgumentParser(
        prog="kai",
        description="Submit and manage jobs on the KAI Scheduler cluster.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
        examples:
          kai submit --image pytorch:24.01 --gpu 1 -- python train.py
          kai submit --image pytorch:24.01 --gpu 2 --node carnaroli -- torchrun --nproc=2 train.py
          kai submit --image pytorch:24.01 --gpu 1 --queue preemptible -- python explore.py
          kai submit --image pytorch:24.01 --gpu 1 --gpu-type h200 --interactive
          kai submit --image pytorch:24.01 --gpu 1 -v /data/datasets:/data -w /workspace -- python train.py
          kai submit --image pytorch:24.01 --gpu 1 --large-shm -- python train.py
          kai submit --image pytorch:24.01 --gpu 1 --attach -- /bin/bash -lc 'source ~/.bashrc; exec bash'
          kai submit --image jupyter/base-notebook --port 8888 -- jupyter lab --ip=0.0.0.0
          kai port-forward my-job 8888:8888
          kai list
          kai logs my-job -f
          kai gpus
          kai delete my-job
          kai queue list
          kai queue create --name fast --quota 4 --priority 200
          kai queue delete fast
        """),
    )
    parser.add_argument("--kubeconfig", metavar="PATH",
                        help="Path to kubeconfig (overrides KUBECONFIG env var and config file)")
    parser.add_argument("--namespace", metavar="NS",
                        help="Kubernetes namespace (overrides KAI_NAMESPACE env var and config file)")
    parser.add_argument("--config", metavar="PATH",
                        help="Path to kai config file (default: ~/.kai/config.yaml)")
    sub = parser.add_subparsers(dest="cmd", metavar="COMMAND")
    sub.required = True

    # ── submit ──
    p = sub.add_parser("submit", help="Submit a job",
                       formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("--image", "-i", required=True, metavar="IMAGE",
                   help="Container image")
    p.add_argument("--name", "-n", metavar="NAME",
                   help="Job name (auto-generated if omitted)")
    p.add_argument("--gpu", "-g", type=int, default=0, metavar="N",
                   help="Number of GPUs to request (default: 0)")
    p.add_argument("--cpu", metavar="CORES",
                   help="CPU request, e.g. '4' or '4000m' (default: 4 per GPU)")
    p.add_argument("--memory", "--mem", metavar="SIZE",
                   help="Memory request, e.g. '32Gi' (default: 32Gi per GPU)")
    p.add_argument("--queue", "-q", default=None,
                   help=f"Queue to submit to (default from config: {DEFAULT_QUEUE})")
    p.add_argument("--node", metavar="HOSTNAME",
                   help="Pin job to a specific node: carnaroli, jasmine, hylian, koshihikari")
    p.add_argument("--gpu-type", metavar="TYPE",
                   help="Pin to a GPU type: h200, 6000/blackwell, 4090, 4000/ada")
    p.add_argument("--interactive", action="store_true",
                   help="Start an interactive shell session (runs sleep+exec; creates a Pod)")
    p.add_argument("--attach", action="store_true",
                   help="Submit the job and attach stdin/tty to it (runs your -- command directly)")
    p.add_argument("--large-shm", action="store_true",
                   help="Replace /dev/shm with an in-memory emptyDir (no size cap; needed for PyTorch multiprocessing)")
    p.add_argument("--backoff-limit", type=int, metavar="N",
                   help="Retry limit (default: 10 for preemptible, 0 for guaranteed queues)")
    p.add_argument("--env", action="append", metavar="KEY=VALUE",
                   help="Set an environment variable (repeatable)")
    p.add_argument("--volume", "-v", action="append", metavar="HOST:CONTAINER[:ro]",
                   help="Mount a host directory into the container (repeatable)")
    p.add_argument("--port", "-p", action="append", metavar="PORT",
                   help="Declare a container port (repeatable; use port-forward to access)")
    p.add_argument("--workdir", "-w", metavar="PATH",
                   help="Set the working directory inside the container")
    p.add_argument("command", nargs=argparse.REMAINDER, metavar="-- COMMAND [ARGS]",
                   help="Command to run inside the container (after --)")
    p.set_defaults(func=cmd_submit)

    # ── port-forward ──
    p = sub.add_parser("port-forward", aliases=["pf"],
                       help="Forward a local port to a running job or pod")
    p.add_argument("target", metavar="JOB_OR_POD",
                   help="Job name (finds its active pod) or pod name")
