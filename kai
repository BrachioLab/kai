def _build_and_push_config(username, role, queue, lab_name, commit_msg=None):
    """Build a CLI config for a user and push it to GitHub (or write locally)."""
    config_base_url = CONFIG_BASE_URL or _read_configs_repo()
    if not config_base_url:
        _die(
            "config_base_url is not set — cannot push user config to GitHub.\n"
            "  Re-run install.sh and enter the configs repository, or set\n"
            "  config_base_url in ~/.kai/config.yaml."
        )
    # If targeting a different namespace, substitute it into the base URL so
    # the config lands in the right directory in the configs repo.
    if NAMESPACE:
        base, _, _ = config_base_url.rstrip("/").rpartition("/")
        config_base_url = f"{base}/{NAMESPACE}"

    cli_cfg = {
        "namespace":     NAMESPACE,
        "default_queue": queue,
        "role":          role,
        "kubeconfig":    "~/.kai/kubeconfig.yaml",
        "config_url":    f"{config_base_url}/{username}.yaml",
        "config_base_url": config_base_url,
    }
    if role == "lab-manager":
        cli_cfg["parent_queue"] = lab_name
    if QUEUE_NODES:
        # Store lists as-is; single-element lists back to string for clean YAML
        cli_cfg["queue_nodes"] = {
            k: (v[0] if len(v) == 1 else v) for k, v in QUEUE_NODES.items()
        }

    owner, repo, branch, path_prefix = _parse_raw_github_url(config_base_url)
    config_gh_path = f"{path_prefix}/{username}.yaml" if path_prefix else f"{username}.yaml"
    config_content = yaml.dump(cli_cfg, default_flow_style=False, sort_keys=False)

    config_file = f"kai-config-{username}.yaml"
    with open(config_file, "w") as f:
        f.write(config_content)

    token = os.environ.get("KAI_GITHUB_TOKEN") or _read_github_token()
    msg = commit_msg or f"update {username} in {NAMESPACE}"
    if token:
        print(f"Pushing config to github.com/{owner}/{repo}...", end=" ", flush=True)
        _github_push_file(owner, repo, branch, config_gh_path, config_content, msg, token)
        print("done")
    else:
        _git_push_config(owner, repo, branch, config_gh_path, config_content, msg)
    # Keep local config in sync so `kai update` doesn't immediately flag a diff
    local_config_path = os.path.join(_KAI_HOME, "config.yaml")
    with open(local_config_path, "w") as f:
        f.write(config_content)

    print(f"✓  {username}  [{role}]  namespace:{NAMESPACE}  queue:{queue}")
    print(f"   cli config → github.com/{owner}/{repo}/{config_gh_path}")


