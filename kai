#!/usr/bin/env python3
"""
kai — generic CLI for the KAI Scheduler.

Usage:
  kai setup [CONFIG] KUBECONFIG    Install config and kubeconfig (CONFIG auto-fetched if configs repo is set)
  kai install                      Add update check hook to shell rc
  kai update [--quiet] [--force]   Check for config update; prompts before applying
  kai self-update                  Upgrade kai itself from GitHub
  kai submit --image IMAGE [--gpu N] [--queue Q] [--node NODE] [-- CMD...]
  kai list / kai pods / kai gpus
  kai logs JOB [-f] / kai describe JOB / kai delete JOB...
  kai exec JOB_OR_POD [-- CMD]
  kai bash JOB_OR_POD              Open an interactive bash shell in a running job
  kai add-user --name NAME [--role ROLE]
  kai queue list / create / delete

Environment:
  KUBECONFIG         Path to kubeconfig
  KAI_NAMESPACE      Override namespace
  KAI_CONFIG         Override config file path
  KAI_GITHUB_TOKEN   GitHub token for fetching configs from private repos
"""

