# ── logs ───────────────────────────────────────────────────────────────────────

def cmd_logs(args):
    flags = ["-f"] if args.follow else []
    kubectl("logs", "-l", f"job-name={args.job}",
            "--tail", str(args.tail), *flags, capture=False, check=False)

# ── delete ─────────────────────────────────────────────────────────────────────

def cmd_delete(args):
    for name in args.names:
        r = kubectl("delete", "job", name, "--ignore-not-found", capture=True, check=False)
        if "deleted" in r.stdout:
            print(f"job/{name} deleted")
            continue
        r2 = kubectl("delete", "pod", name, "--ignore-not-found", capture=True, check=False)
        if "deleted" in r2.stdout:
            print(f"pod/{name} deleted")
        else:
            print(f"not found: {name}")

# ── describe ───────────────────────────────────────────────────────────────────

def cmd_describe(args):
    r = kubectl("describe", "job", args.name, capture=True, check=False)
    if r.returncode == 0:
        print(r.stdout)
    else:
        kubectl("describe", "pod", args.name, capture=False, check=False)

# ── exec ───────────────────────────────────────────────────────────────────────

def cmd_exec(args):
    cmd  = args.command or ["bash"]
    pod  = _resolve_pod(args.pod)
    tty_flags = ["-it"] if sys.stdin.isatty() else ["-i"]
    kubectl("exec", *tty_flags, pod, "--", *cmd, capture=False, check=False)

def cmd_bash(args):
    """Open an interactive bash shell in a running job (equivalent to runai bash)."""
    pod = _resolve_pod(args.pod)
    kubectl("exec", "-it", pod, "--", "bash", capture=False, check=False)

# ── gpus ───────────────────────────────────────────────────────────────────────

def cmd_gpus(args):
    r = kubectl("get", "pods", "-o", "json", capture=True)
    pods = json.loads(r.stdout).get("items", [])

    # Count GPU requests for Running/Pending pods per node
    allocated = {}
    for pod in pods:
        phase    = pod.get("status", {}).get("phase", "")
        node     = pod.get("spec", {}).get("nodeName") or "_pending"
        if phase not in ("Running", "Pending"):
            continue
        for c in pod.get("spec", {}).get("containers", []):
            gpus = int(c.get("resources", {}).get("limits", {}).get("nvidia.com/gpu", 0))
            if gpus:
                allocated[node] = allocated.get(node, 0) + gpus

    rows = []
    total_count = total_used = 0
    for node, info in GPU_NODES.items():
        used  = allocated.get(node, 0)
        free  = info["count"] - used
        rows.append((
            node,
            f"{info['name']} ({info['mem_gb']}GB)",
            str(info["count"]),
            str(used),
            str(free),
        ))
        total_count += info["count"]
        total_used  += used

    _print_table(
        ("NODE", "GPU", "TOTAL", "USED", "FREE"),
        rows,
        footer=("TOTAL", "", str(total_count), str(total_used), str(total_count - total_used)),
    )

