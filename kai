def cmd_logs(args):
    if args.follow:
        # Resolve pod name directly — kubectl logs -l ... -f is unreliable for streaming
        r = kubectl("get", "pods", "-l", f"job-name={args.job}",
                    "-o", "jsonpath={.items[0].status.phase} {.items[0].metadata.name}",
                    capture=True, check=False)
        parts = r.stdout.strip().split()
        phase, pod = (parts[0], parts[1]) if len(parts) == 2 else ("", "")
        if phase not in ("Running", "Succeeded", "Failed"):
            print(f"Waiting for {args.job} pod to start (status: {phase or 'Pending'})...")
            pod = _wait_for_job_pod(args.job, timeout=600)
        kubectl("logs", pod, "--tail", str(args.tail), "-f", capture=False, check=False)
        return
    kubectl("logs", "-l", f"job-name={args.job}",
            "--tail", str(args.tail), capture=False, check=False)

