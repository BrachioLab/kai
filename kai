def cmd_add_user(args):
    """Create a new user: SA + token + RoleBinding, then write kubeconfig + CLI config locally."""
    # Read cluster server + CA from the current kubeconfig
    try:
        with open(os.path.expanduser(KUBECONFIG)) as f:
            kc = yaml.safe_load(f)
        cluster = kc["clusters"][0]["cluster"]
        kube_server = cluster["server"]
        kube_ca     = cluster["certificate-authority-data"]
    except Exception as e:
        _die(f"Could not read cluster info from {KUBECONFIG}: {e}")

    lab_name = PARENT_QUEUE or NAMESPACE

    # Create ServiceAccount
    kubectl("apply", "-f", "-", stdin_data=json.dumps({
        "apiVersion": "v1",
        "kind": "ServiceAccount",
        "metadata": {"name": args.name, "namespace": NAMESPACE},
    }))

    # Create long-lived token Secret
    kubectl("apply", "-f", "-", stdin_data=json.dumps({
        "apiVersion": "v1",
        "kind": "Secret",
        "metadata": {
            "name": f"{args.name}-token",
            "namespace": NAMESPACE,
            "annotations": {"kubernetes.io/service-account.name": args.name},
        },
        "type": "kubernetes.io/service-account-token",
    }))

    # Wait for the token controller to populate the secret
    print("Waiting for token", end="", flush=True)
    deadline = time.time() + 60
    sa_token = None
    while time.time() < deadline:
        r = kubectl("get", "secret", f"{args.name}-token", "-o", "json", capture=True, check=False)
        if r.returncode == 0:
            raw = json.loads(r.stdout).get("data", {}).get("token")
            if raw:
                sa_token = base64.b64decode(raw).decode()
                break
        print(".", end="", flush=True)
        time.sleep(2)
    print()
    if not sa_token:
        _die(f"Timed out waiting for token for {args.name}")

    # Create RoleBinding
    kubectl("apply", "-f", "-", stdin_data=json.dumps({
        "apiVersion": "rbac.authorization.k8s.io/v1",
        "kind": "RoleBinding",
        "metadata": {"name": f"{args.name}-binding", "namespace": NAMESPACE},
        "subjects": [{"kind": "ServiceAccount", "name": args.name, "namespace": NAMESPACE}],
        "roleRef": {"kind": "Role", "name": args.role, "apiGroup": "rbac.authorization.k8s.io"},
    }))

    # Write kubeconfig — user places this at ~/.kai/kubeconfig.yaml
    context_name = f"{NAMESPACE}-{args.name}"
    kubeconfig_out = {
        "apiVersion": "v1",
        "kind": "Config",
        "clusters": [{"cluster": {"certificate-authority-data": kube_ca, "server": kube_server},
                      "name": f"{lab_name}-cluster"}],
        "contexts": [{"context": {"cluster": f"{lab_name}-cluster", "namespace": NAMESPACE, "user": args.name},
                      "name": context_name}],
        "current-context": context_name,
        "users": [{"name": args.name, "user": {"token": sa_token}}],
    }
    kubeconfig_file = f"kai-kubeconfig-{args.name}.yaml"
    with open(kubeconfig_file, "w") as f:
        yaml.dump(kubeconfig_out, f, default_flow_style=False, sort_keys=False)
    os.chmod(kubeconfig_file, 0o600)

    queue = getattr(args, "queue", None) or DEFAULT_QUEUE
    _build_and_push_config(args.name, args.role, queue, lab_name,
                           commit_msg=f"add {args.name} to {NAMESPACE}")

    print(f"\n   kubeconfig : {kubeconfig_file}  ← keep secret, share via secure channel")
    print()
    print("   Share with the user:")
    print(f"     1. Send {kubeconfig_file} securely (Slack DM, encrypted email, etc.)")
    print(f"     2. User runs on their machine:")
    print(f"          kai setup {kubeconfig_file}")

    if args.role == "lab-manager":
        crb = f"{NAMESPACE}-{args.name}-queue-manager"
        sa  = f"{NAMESPACE}:{args.name}"
        print()
        print("  !! ADMIN STEP REQUIRED ".ljust(71, "!"))
        print("  Lab managers need a ClusterRoleBinding to manage queues.")
        print("  This cannot be granted with a lab-manager kubeconfig.")
        print()
        print("  An admin must run:")
        print(f"    kubectl create clusterrolebinding {crb} \\")
        print(f"      --clusterrole=lab-manager-queues \\")
        print(f"      --serviceaccount={sa}")
        print()
        print("  Without this the user can submit jobs but not create/delete queues.")
        print("  " + "!" * 69)

