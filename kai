_VERSION  = "0.5.3"
_KAI_HOME = os.path.expanduser("~/.kai")

# Namespace for all workloads.
# Override with --namespace flag or KAI_NAMESPACE env var.
NAMESPACE = os.environ.get("KAI_NAMESPACE", "")

# Default kubeconfig: ../kubeconfig.yaml relative to this script
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
_DEFAULT_KUBECONFIG = os.path.join(_SCRIPT_DIR, "..", "kubeconfig.yaml")
KUBECONFIG = os.environ.get("KUBECONFIG", _DEFAULT_KUBECONFIG)

# URL of the kai script itself in the public repo — used by self-update
_KAI_SCRIPT_URL = "https://raw.githubusercontent.com/BrachioLab/kai/main/kai"

# Populated from config file
DEFAULT_QUEUE   = "preemptible"   # bare lane name; namespace is prepended at submit (-> <ns>-preemptible)
NAMESPACE_QUEUES = False   # opt-in (config `namespace_queues: true`): prepend the namespace to a bare
                           # queue lane (<ns>-<lane>). OFF by default so clusters with plain queue
                           # names (e.g. the testbed's `default`/`preemptible`) keep working.
ALLOWED_QUEUES  = None   # None = unrestricted (admin/no config file)
ROLE            = None
PARENT_QUEUE    = None
CONFIG_URL      = None   # Raw URL to fetch this user's config from GitHub
CONFIG_BASE_URL = None   # Base URL for generating config URLs for new users
QUEUE_NODES     = {}     # queue name → node hostname (client-side node selector)
_DEFAULT_BACKOFF_LIMIT = 10   # job retries after eviction/preemption unless --backoff-limit overrides


def _resolve_queue(q):
    """A bare lane name (no '-', e.g. 'priority'/'preemptible'/'collaborators')
    gets the namespace prepended: 'priority' -> '<namespace>-priority'. A
    fully-qualified queue name (already contains '-') is used verbatim."""
    if q and "-" not in q and NAMESPACE and NAMESPACE_QUEUES:
        return "{}-{}".format(NAMESPACE, q)
    return q


def _priority_for_queue(q):
    """Derive the KAI priority class from the queue lane (no --priority flag):
    guaranteed lanes (*-priority / *-collaborators) are non-preemptible ('build');
    everything else (the *-preemptible borrow lane) is preemptible ('train')."""
    if q and (q.endswith("-priority") or q.endswith("-collaborators")):
        return "build"
    return "train"


def _load_config(explicit_path=None):
    """Load kai config file; update globals with its values."""
    global NAMESPACE, KUBECONFIG, DEFAULT_QUEUE, ALLOWED_QUEUES, ROLE, PARENT_QUEUE, NAMESPACE_QUEUES
    global CONFIG_URL, CONFIG_BASE_URL, QUEUE_NODES

    paths = []
    if explicit_path:
        paths = [explicit_path]
    elif os.environ.get("KAI_CONFIG"):
        paths = [os.environ["KAI_CONFIG"]]
    else:
        paths = [
            os.path.join(_KAI_HOME, "config.yaml"),
        ]

    cfg = {}
    for p in paths:
        if os.path.exists(p):
            try:
                with open(p) as f:
                    cfg = yaml.safe_load(f) or {}
            except Exception as e:
                print(f"warning: could not read config {p}: {e}", file=sys.stderr)
            break

    if cfg.get("namespace") and not os.environ.get("KAI_NAMESPACE"):
        NAMESPACE = cfg["namespace"]
    if cfg.get("kubeconfig"):
        KUBECONFIG = os.path.expanduser(cfg["kubeconfig"])
    if cfg.get("default_queue"):
        DEFAULT_QUEUE = cfg["default_queue"]
    if cfg.get("namespace_queues"):
        NAMESPACE_QUEUES = True
    if cfg.get("allowed_queues") is not None:
        ALLOWED_QUEUES = list(cfg["allowed_queues"])
    if cfg.get("role"):
        ROLE = cfg["role"]
    if cfg.get("parent_queue"):
        PARENT_QUEUE = cfg["parent_queue"]
    if cfg.get("config_url"):
        CONFIG_URL = cfg["config_url"]
    if cfg.get("config_base_url"):
        CONFIG_BASE_URL = cfg["config_base_url"]
    if cfg.get("queue_nodes"):
        # Normalize values to lists (string → [string]) so the rest of the code is uniform
        QUEUE_NODES = {
            k: ([v] if isinstance(v, str) else list(v))
            for k, v in cfg["queue_nodes"].items()
        }


def _read_github_token():
    """Read GitHub token from credentials file, for fetching configs from private repos."""
    cred_path = os.path.join(_KAI_HOME, "credentials")
    try:
        with open(cred_path) as f:
            creds = yaml.safe_load(f) or {}
        return creds.get("github_token")
    except FileNotFoundError:
        return None


def _read_configs_repo():
    """Read the configs repo base URL from ~/.kai/configs_repo (set during install)."""
    path = os.path.join(_KAI_HOME, "configs_repo")
    try:
        with open(path) as f:
            return f.read().strip() or None
    except FileNotFoundError:
        return None

def _parse_raw_github_url(url):
    """Parse https://raw.githubusercontent.com/OWNER/REPO/BRANCH/PATH → (owner, repo, branch, path_prefix)."""
    prefix = "https://raw.githubusercontent.com/"
    if not url.startswith(prefix):
        _die(f"config_base_url must be a raw.githubusercontent.com URL, got: {url}")
    parts = url[len(prefix):].split("/", 3)
    if len(parts) < 3:
        _die(f"config_base_url is malformed: {url}")
    return parts[0], parts[1], parts[2], (parts[3] if len(parts) > 3 else "")


def _github_push_file(owner, repo, branch, path, content, message, token):
    """Create or update a file in a GitHub repo via the Contents API."""
    api_url = f"https://api.github.com/repos/{owner}/{repo}/contents/{path}"
    headers = {
        "Authorization": f"token {token}",
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": "2022-11-28",
        "Content-Type": "application/json",
    }
    sha = None
    try:
        req = urllib.request.Request(api_url, headers=headers)
        with urllib.request.urlopen(req, timeout=10) as resp:
            sha = json.loads(resp.read()).get("sha")
    except urllib.error.HTTPError as e:
        if e.code != 404:
            _die(f"GitHub API error {e.code} checking {path}: {e.read().decode()}")

    body = {
        "message": message,
        "content": base64.b64encode(content.encode()).decode(),
        "branch": branch,
    }
    if sha:
        body["sha"] = sha

    req = urllib.request.Request(
        api_url, data=json.dumps(body).encode(), headers=headers, method="PUT"
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        _die(f"GitHub API error {e.code} pushing {path}: {e.read().decode()}")


def _git_push_config(owner, repo, branch, path, content, message):
    """Commit and push a config file via git, using a local clone in ~/.kai/configs/."""
    clone_dir = os.path.join(_KAI_HOME, "configs")
    clone_url = f"git@github.com:{owner}/{repo}.git"

    if os.path.isdir(os.path.join(clone_dir, ".git")):
        # Ensure the remote uses SSH (migrate old HTTPS clones)
        subprocess.run(["git", "-C", clone_dir, "remote", "set-url", "origin", clone_url],
                       check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        print(f"Pulling latest from github.com/{owner}/{repo}...", end=" ", flush=True)
        result = subprocess.run(["git", "-C", clone_dir, "pull", "--quiet"],
                                stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True)
        if result.returncode != 0:
            _die(f"git pull failed:\n{result.stderr.strip()}")
    else:
        print(f"Cloning github.com/{owner}/{repo}...", end=" ", flush=True)
        result = subprocess.run(["git", "clone", "--quiet", clone_url, clone_dir],
                                stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True)
        if result.returncode != 0:
            _die(f"git clone failed:\n{result.stderr.strip()}")
    print("done")

    file_path = os.path.join(clone_dir, path)
    os.makedirs(os.path.dirname(file_path), exist_ok=True)
    with open(file_path, "w") as f:
        f.write(content)

    subprocess.run(["git", "-C", clone_dir, "add", path], check=True)
    result = subprocess.run(
        ["git", "-C", clone_dir, "commit", "-m", message],
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True,
    )
    if result.returncode != 0 and "nothing to commit" not in result.stdout:
        _die(f"git commit failed:\n{result.stderr.strip()}")

    print(f"Pushing to github.com/{owner}/{repo}...", end=" ", flush=True)
    result = subprocess.run(["git", "-C", clone_dir, "push", "--quiet"],
                            stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True)
    if result.returncode != 0:
        _die(f"git push failed:\n{result.stderr.strip()}")
    print("done")


