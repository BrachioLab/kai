    # ── install ──
    p = sub.add_parser("install", help="Add login update hook to ~/.bashrc or ~/.zshrc")
    p.set_defaults(func=cmd_install)

    # ── queue ──
    p = sub.add_parser("queue", help="Manage KAI scheduler queues (lab-manager only)")
    qsub = p.add_subparsers(dest="queue_cmd", metavar="SUBCOMMAND")
    qsub.required = True

    qp = qsub.add_parser("list", help="List all queues")
    qp = qsub.add_parser("create", help="Create a new child queue")
    qp.add_argument("--name", required=True, metavar="NAME", help="Queue name")
    qp.add_argument("--quota", type=int, default=0, metavar="N",
                    help="GPU quota floor (default: 0 = no guarantee)")
    qp.add_argument("--priority", type=int, default=100, metavar="N",
                    help="Priority (default: 100; 0 = preemptible)")
    qp.add_argument("--parent", metavar="QUEUE",
                    help="Parent queue name (default: from config file)")
    qp.add_argument("--node", metavar="HOSTNAME", action="append",
                    help="Pin jobs to a node (repeatable for multi-node groups: --node jasmine --node carnaroli)")
