def cmd_setup(args):
    """Install kubeconfig and CLI config from files into ~/.kai/."""
    os.makedirs(_KAI_HOME, mode=0o700, exist_ok=True)

    kubeconfig_dest = os.path.join(_KAI_HOME, "kubeconfig.yaml")
    shutil.copy2(args.kubeconfig_file, kubeconfig_dest)
    os.chmod(kubeconfig_dest, 0o600)
    print(f"✓ kubeconfig → {kubeconfig_dest}")

    config_dest = os.path.join(_KAI_HOME, "config.yaml")

    if args.config_file:
        shutil.copy2(args.config_file, config_dest)
        print(f"✓ config     → {config_dest}")
        try:
            with open(args.config_file) as f:
                cfg = yaml.safe_load(f) or {}
        except Exception:
            cfg = {}
    else:
        # Auto-fetch config from configs_repo using namespace from kubeconfig and $USER
        configs_repo = _read_configs_repo()
        if not configs_repo:
            _die(
                "No config file provided and no configs repo set.\n"
                "  Either provide a config file:\n"
                "    kai setup <config.yaml> <kubeconfig.yaml>\n"
                "  Or re-run install.sh and enter the configs repository."
            )
        username = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
        if not username:
            _die("Could not determine username from $USER — provide a config file explicitly.")
        config_url = f"{configs_repo}/{username}.yaml"
        print(f"Fetching config for '{username}' ...", end=" ", flush=True)
        try:
            req = urllib.request.Request(config_url)
            with urllib.request.urlopen(req, timeout=10) as resp:
                config_content = resp.read().decode()
        except urllib.error.HTTPError as e:
            if e.code == 404:
                print()
                _die(
                    f"No config found for '{username}'.\n"
                    f"  Ask your lab manager to run: kai add-user --name {username}"
                )
            _die(f"Failed to fetch config: HTTP {e.code}")
        except Exception as e:
            _die(f"Failed to fetch config: {e}")
        print("done")
        with open(config_dest, "w") as f:
            f.write(config_content)
        print(f"✓ config     → {config_dest}")
        cfg = yaml.safe_load(config_content) or {}

    # Persist config_url so kai update survives config rewrites
    url = cfg.get("config_url")
    if url:
        url_file = os.path.join(_KAI_HOME, "config_url")
        with open(url_file, "w") as f:
            f.write(url.strip() + "\n")
        print(f"✓ config_url → {url_file}")

    # Store GitHub token if provided via --github-token flag
    token = getattr(args, "github_token", None)
    if token:
        cred_path = os.path.join(_KAI_HOME, "credentials")
        try:
            with open(cred_path) as f:
                creds = yaml.safe_load(f) or {}
        except FileNotFoundError:
            creds = {}
        creds["github_token"] = token
        with open(cred_path, "w") as f:
            yaml.dump(creds, f, default_flow_style=False, sort_keys=False)
        os.chmod(cred_path, 0o600)
        print(f"✓ github_token → {cred_path}")

    print()
    print("Run 'kai install' to enable automatic config updates on login.")


def _fetch_config_update():
    """Fetch latest config from config_url. Returns (new_content, current_content) or (None, None) on error/no-change."""
    url = None
    url_file = os.path.join(_KAI_HOME, "config_url")
    try:
        with open(url_file) as f:
            url = f.read().strip() or None
    except FileNotFoundError:
        pass
    if not url:
        url = CONFIG_URL
    if not url:
        return None, None

    headers = {}
    token = os.environ.get("KAI_GITHUB_TOKEN") or _read_github_token()
    if token:
        headers["Authorization"] = f"token {token}"

    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=5) as resp:
            new_content = resp.read().decode()
    except Exception:
        return None, None

    config_path = os.path.join(_KAI_HOME, "config.yaml")
    try:
        with open(config_path) as f:
            current = f.read()
    except FileNotFoundError:
        current = ""

    return new_content, current


def cmd_update(args):
    """Fetch latest config from config_url and prompt before applying if changed.

    --quiet: suppress the "up to date" message, but still prompt if an update is available.
    --force: apply without prompting (for scripted use).
    """
    quiet = getattr(args, "quiet", False)
    force = getattr(args, "force", False)

    url_file = os.path.join(_KAI_HOME, "config_url")
    has_url = os.path.exists(url_file) or bool(CONFIG_URL)
    if not has_url:
        if not quiet:
            print("kai: no config_url set — nothing to update", file=sys.stderr)
        return

    new_content, current = _fetch_config_update()
    if new_content is None:
        if not quiet:
            print("kai: update check failed", file=sys.stderr)
        return

    if new_content.strip() == current.strip():
        if not quiet:
            print("kai config is up to date")
        return

    # An update is available — always prompt unless --force
    if not force:
        print()
        print("[kai] A config update is available.")
        sys.stdout.write("[kai] Would you like to apply it? [Y/n] ")
        sys.stdout.flush()
        try:
            answer = sys.stdin.readline().strip().lower()
        except (KeyboardInterrupt, EOFError):
            print()
            return
        if answer not in ("", "y", "yes"):
            print("[kai] Skipped. Run 'kai update' to apply manually.")
            print()
            return
        print()

    config_path = os.path.join(_KAI_HOME, "config.yaml")
    os.makedirs(_KAI_HOME, mode=0o700, exist_ok=True)
    with open(config_path, "w") as f:
        f.write(new_content)
    print("[kai] Config updated.")


_INSTALL_HOOK = (
    "# kai: check for updates on login\n"
    "kai self-update --quiet 2>/dev/null\n"
    "kai update --quiet 2>/dev/null\n"
)
# Sentinel that appears only in the current hook — used to detect stale versions
_INSTALL_HOOK_SENTINEL = "kai self-update --quiet"
# Sentinel that appears in any kai hook (old or new) — used to find the block to replace
_INSTALL_HOOK_ANY = "# kai: check for"


def cmd_install(args):
    """Add (or update) the login hook in ~/.bashrc or ~/.zshrc."""
    shell = os.path.basename(os.environ.get("SHELL", "bash"))
    rc_path = os.path.expanduser("~/.zshrc" if shell == "zsh" else "~/.bashrc")

    try:
        with open(rc_path) as f:
            content = f.read()
    except FileNotFoundError:
        content = ""

    if _INSTALL_HOOK_SENTINEL in content:
        print(f"Login hook is already up to date in {rc_path}")
        return

    if _INSTALL_HOOK_ANY in content:
        # Replace stale hook block (comment + following kai lines) with current hook
        import re
        new_content = re.sub(
            r"# kai: check for[^\n]*\n(?:kai [^\n]+\n)*",
            _INSTALL_HOOK,
            content,
        )
        with open(rc_path, "w") as f:
            f.write(new_content)
        print(f"✓ Login hook updated in {rc_path}")
    else:
        with open(rc_path, "a") as f:
            f.write(f"\n{_INSTALL_HOOK}")
        print(f"✓ Login hook added to {rc_path}")
    print(f"  Takes effect in new shell sessions (or: source {rc_path})")


def cmd_self_update(args):
    """Check for a new kai binary and prompt before replacing it.

    --quiet: suppress 'up to date' message (still prompts if update available).
    --force: apply without prompting.
    """
    quiet = getattr(args, "quiet", False)
    force = getattr(args, "force", False)

    kai_bin = os.path.join(_KAI_HOME, "bin", "kai")
    if not os.path.exists(kai_bin):
        if not quiet:
            _die(
                "kai binary not found at ~/.kai/bin/kai\n"
                "  Is kai installed via install.sh? If running from source, no self-update needed."
            )
        return

    try:
        req = urllib.request.Request(_KAI_SCRIPT_URL)
        with urllib.request.urlopen(req, timeout=10) as resp:
            new_script = resp.read()
    except Exception as e:
        if not quiet:
            print(f"kai: self-update check failed: {e}", file=sys.stderr)
        return

    try:
        with open(kai_bin, "rb") as f:
            current_script = f.read()
    except Exception:
        current_script = b""

    if new_script == current_script:
        if not quiet:
            print("kai is up to date")
        return

    if not force:
        print()
        print("[kai] A kai update is available.")
        sys.stdout.write("[kai] Would you like to apply it? [Y/n] ")
        sys.stdout.flush()
        try:
            answer = sys.stdin.readline().strip().lower()
        except (KeyboardInterrupt, EOFError):
            print()
            return
        if answer not in ("", "y", "yes"):
            print("[kai] Skipped. Run 'kai self-update' to apply manually.")
            print()
            return
        print()

    with open(kai_bin, "wb") as f:
        f.write(new_script)
    os.chmod(kai_bin, 0o755)
    print("[kai] kai updated to latest version.")


# ── queue management ───────────────────────────────────────────────────────────

def _config_update_queue_node(queue_name, node):
    """Add or remove a queue→node mapping in ~/.kai/config.yaml. Pass node=None to remove."""
    config_path = os.path.join(_KAI_HOME, "config.yaml")
    try:
        with open(config_path) as f:
            cfg = yaml.safe_load(f) or {}
    except FileNotFoundError:
        cfg = {}
    nodes = cfg.get("queue_nodes") or {}
    if node is None:
        nodes.pop(queue_name, None)
    else:
        nodes[queue_name] = node
    if nodes:
        cfg["queue_nodes"] = nodes
    elif "queue_nodes" in cfg:
        del cfg["queue_nodes"]
    with open(config_path, "w") as f:
        yaml.dump(cfg, f, default_flow_style=False, sort_keys=False)


def cmd_queue(args):
    if args.queue_cmd == "list":
        _queue_list()
    elif args.queue_cmd == "create":
        _queue_create(args)
    elif args.queue_cmd == "delete":
        _queue_delete(args)

def _queue_list():
    r = kubectl_global("get", "queues", "-o", "json")
    items = json.loads(r.stdout).get("items", [])
    if not items:
        print("No queues found.")
        return
    rows = []
    for q in items:
        meta   = q["metadata"]
        spec   = q.get("spec", {})
        parent = spec.get("parentQueue", "—")
        prio   = spec.get("priority", "—")
        res    = spec.get("resources", {})
        quota  = res.get("gpu", {}).get("quota", "—")
        node   = QUEUE_NODES.get(meta["name"], "—")
        rows.append((meta["name"], parent, str(prio), str(quota), node))
    _print_table(("NAME", "PARENT", "PRIORITY", "GPU-QUOTA", "NODE"), rows)

def _queue_create(args):
    if ROLE not in ("lab-manager", None) and ROLE != "admin":
        _die("Only lab-managers can create queues.")
    parent = args.parent or PARENT_QUEUE
    if not parent:
        _die("--parent required (or set parent_queue in config file)")
    manifest = {
        "apiVersion": "scheduling.run.ai/v2",
        "kind": "Queue",
        "metadata": {"name": args.name},
        "spec": {
            "parentQueue": parent,
            "priority": args.priority,
            "resources": {
                "gpu":    {"quota": args.quota, "limit": -1, "overQuotaWeight": 1},
                "cpu":    {"quota": -1,          "limit": -1, "overQuotaWeight": 1},
                "memory": {"quota": -1,          "limit": -1, "overQuotaWeight": 1},
            },
        },
    }
    kubectl_global("apply", "-f", "-", stdin_data=json.dumps(manifest))
    msg = f"queue/{args.name} created  [parent: {parent}  priority: {args.priority}  gpu-quota: {args.quota}]"
    if args.node:
        _config_update_queue_node(args.name, args.node)
        msg += f"  node:{args.node}"
        print(msg)
        print(f"  → node selector saved to ~/.kai/config.yaml")
        print(f"  → Re-run 'kai add-user' for existing users and push to distribute")
    else:
        print(msg)

def _queue_delete(args):
    if ROLE not in ("lab-manager", None) and ROLE != "admin":
        _die("Only lab-managers can delete queues.")
    kubectl_global("delete", "queue", args.name)
    if args.name in QUEUE_NODES:
        _config_update_queue_node(args.name, None)
        print(f"queue/{args.name} deleted  (node selector removed from config)")
    else:
        print(f"queue/{args.name} deleted")

