def _cluster_node_names():
    """Set of node names in the cluster, or None if it can't be determined
    (e.g. no node-read permission) — callers skip validation when None so a
    missing kai-nodes-reader ClusterRole never breaks submit/setup."""
    r = kubectl("get", "nodes", "-o", "jsonpath={.items[*].metadata.name}",
                capture=True, check=False)
    if r.returncode != 0 or not r.stdout.strip():
        return None
    return set(r.stdout.split())

def _warn_unknown_nodes(targets, context):
    """Warn (don't silently proceed) if NONE of the target hostnames exist on the
    cluster — that job/queue can never schedule. Skips quietly if nodes aren't
    listable. Returns True if a fatal mismatch (no target exists) was warned."""
    targets = [t for t in (targets or []) if t]
    if not targets:
        return False
    cluster = _cluster_node_names()
    if cluster is None:
        return False
    missing = [t for t in targets if t not in cluster]
    if missing and not any(t in cluster for t in targets):
        print(f"⚠  WARNING: {context} target node(s) do not exist on this cluster:",
              file=sys.stderr)
        print(f"     requested: {', '.join(sorted(set(targets)))}", file=sys.stderr)
        print(f"     cluster has: {', '.join(sorted(cluster))}", file=sys.stderr)
        print("   Such jobs stay Pending forever. This usually means your kai config", file=sys.stderr)
        print("   is from a different cluster's configs repo — check ~/.kai/configs_repo", file=sys.stderr)
        print("   and re-run 'kai setup', then resubmit.", file=sys.stderr)
        return True
    return False

def _warn_setup_queue_nodes(cfg, kubeconfig_path):
    """At setup time, warn if the config's queue→node mappings reference nodes
    that don't exist on this cluster (the usual sign of a wrong configs repo)."""
    qn = cfg.get("queue_nodes") or {}
    if not qn:
        return
    global KUBECONFIG, NAMESPACE
    KUBECONFIG = kubeconfig_path
    if cfg.get("namespace"):
        NAMESPACE = cfg["namespace"]
    referenced = set()
    for v in qn.values():
        referenced.update([v] if isinstance(v, str) else list(v))
    cluster = _cluster_node_names()
    if cluster is None:
        return
    missing = sorted(n for n in referenced if n not in cluster)
    if missing:
        print(file=sys.stderr)
        print("⚠  WARNING: your config maps queues to nodes NOT on this cluster:", file=sys.stderr)
        print(f"     missing:     {', '.join(missing)}", file=sys.stderr)
        print(f"     cluster has: {', '.join(sorted(cluster))}", file=sys.stderr)
        print("   Jobs to those queues will stay Pending. Your configs repo may be for", file=sys.stderr)
        print("   a different cluster — verify ~/.kai/configs_repo.", file=sys.stderr)

def _discover_gpu_nodes():
    """Discover GPU nodes from the cluster. Count comes from node capacity;
    product/memory from GPU Feature Discovery labels (set by the GPU operator).
    Returns {node: {name, product, count, mem_gb}}. No hardcoding — works on
    any cluster. Requires node read (the kai-nodes-reader ClusterRole)."""
    r = kubectl("get", "nodes", "-o", "json", capture=True)
    out = {}
    for n in json.loads(r.stdout).get("items", []):
        cap   = n.get("status", {}).get("capacity", {})
        count = int(cap.get("nvidia.com/gpu", 0) or 0)
        if count <= 0:
            continue
        labels  = n["metadata"].get("labels", {})
        product = labels.get("nvidia.com/gpu.product", "GPU")
        mem_mib = labels.get("nvidia.com/gpu.memory")
        try:
            mem_gb = int(round(int(mem_mib) / 1024)) if mem_mib else None
        except (ValueError, TypeError):
            mem_gb = None
        out[n["metadata"]["name"]] = {
            "name":    product.replace("NVIDIA-", "").replace("-", " "),
            "product": product,
            "count":   count,
            "mem_gb":  mem_gb,
        }
    return out

def _gpu_allocation():
    """{node: GPUs currently requested} across all namespaces (Running/Pending)."""
    r = kubectl("get", "pods", "--all-namespaces", "-o", "json", capture=True)
    alloc = {}
    for pod in json.loads(r.stdout).get("items", []):
        if pod.get("status", {}).get("phase") not in ("Running", "Pending"):
            continue
        node = pod.get("spec", {}).get("nodeName")
        if not node:
            continue
        for c in pod.get("spec", {}).get("containers", []):
            g = int(c.get("resources", {}).get("limits", {}).get("nvidia.com/gpu", 0) or 0)
            if g:
                alloc[node] = alloc.get(node, 0) + g
    return alloc


def _queue_allocation():
    """{queue name: GPUs currently requested} across all namespaces (Running/Pending)."""
    r = kubectl("get", "pods", "--all-namespaces", "-o", "json", capture=True)
    alloc = {}
    for pod in json.loads(r.stdout).get("items", []):
        if pod.get("status", {}).get("phase") not in ("Running", "Pending"):
            continue
        q = pod.get("metadata", {}).get("labels", {}).get("kai.scheduler/queue")
        if not q:
            continue
        for c in pod.get("spec", {}).get("containers", []):
            g = int(c.get("resources", {}).get("limits", {}).get("nvidia.com/gpu", 0) or 0)
            if g:
                alloc[q] = alloc.get(q, 0) + g
    return alloc


def _queue_free(quota, used):
    """quota - used for finite quotas; '—' for unbounded (-1) / unset parents."""
    return (quota - used) if isinstance(quota, int) and quota >= 0 else "—"

def cmd_gpus(args):
    gpu_nodes = _discover_gpu_nodes()
    if not gpu_nodes:
        print("No GPU nodes found in the cluster.")
        return
    allocated = _gpu_allocation()

    rows = []
    total_count = total_used = 0
    for node, info in sorted(gpu_nodes.items()):
        used  = allocated.get(node, 0)
        count = info["count"]
        mem   = f" ({info['mem_gb']}GB)" if info["mem_gb"] else ""
        rows.append((node, f"{info['name']}{mem}", str(count), str(used), str(count - used)))
        total_count += count
        total_used  += used

    _print_table(
        ("NODE", "GPU", "TOTAL", "USED", "FREE"),
        rows,
        footer=("TOTAL", "", str(total_count), str(total_used), str(total_count - total_used)),
    )

