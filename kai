          kai submit --image pytorch:24.01 --gpu 1 --queue priority -- python train.py   # guaranteed on your lab's nodes
          kai submit --image pytorch:24.01 --gpu 1 --queue preemptible --gpu-type a6000 -- python explore.py   # borrow any idle A6000
          kai submit --image pytorch:24.01 --gpu 1 --gpu-type h200 --interactive
