    qp.add_argument("name", metavar="NAME", help="Queue name")
    p.set_defaults(func=cmd_queue)

    args = parser.parse_args()

    # Re-load config with explicit --config path if given, then apply CLI overrides
    if args.config:
        _load_config(explicit_path=args.config)
    if args.kubeconfig:
        KUBECONFIG = args.kubeconfig
    if args.namespace:
        NAMESPACE = args.namespace

    # Apply DEFAULT_QUEUE for submit if --queue was not specified
    if getattr(args, "queue", None) is None and hasattr(args, "queue"):
        args.queue = DEFAULT_QUEUE

    # Strip leading '--' from remainder args (submit and exec)
    for field in ("command",):
        val = getattr(args, field, None)
        if isinstance(val, list) and val and val[0] == "--":
            setattr(args, field, val[1:])

    args.func(args)


if __name__ == "__main__":
    main()
