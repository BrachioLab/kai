    except FileNotFoundError:
        content = ""

    if _INSTALL_HOOK_SENTINEL in content:
        print(f"Login hook is already up to date in {rc_path}")
        return

    if _INSTALL_HOOK_ANY in content:
        # Replace stale hook block (comment + following kai lines) with current hook
        import re
        new_content = re.sub(
            r"# kai: check for[^\n]*\n(?:kai [^\n]+\n)*",
            _INSTALL_HOOK,
            content,
        )
        with open(rc_path, "w") as f:
            f.write(new_content)
        print(f"✓ Login hook updated in {rc_path}")
    else:
        with open(rc_path, "a") as f:
            f.write(f"\n{_INSTALL_HOOK}")
        print(f"✓ Login hook added to {rc_path}")
    print(f"  Takes effect in new shell sessions (or: source {rc_path})")




# ── queue management ───────────────────────────────────────────────────────────

def _config_update_queue_node(queue_name, nodes):
    """Add or remove a queue→node(s) mapping in ~/.kai/config.yaml. Pass nodes=None to remove."""
    config_path = os.path.join(_KAI_HOME, "config.yaml")
    try:
        with open(config_path) as f:
            cfg = yaml.safe_load(f) or {}
    except FileNotFoundError:
        cfg = {}
    existing = cfg.get("queue_nodes") or {}
    if nodes is None:
        existing.pop(queue_name, None)
    else:
        # Store as string for single node (clean YAML), list for multiple
        existing[queue_name] = nodes[0] if len(nodes) == 1 else nodes
    if existing:
        cfg["queue_nodes"] = existing
    elif "queue_nodes" in cfg:
        del cfg["queue_nodes"]
    with open(config_path, "w") as f:
        yaml.dump(cfg, f, default_flow_style=False, sort_keys=False)


def cmd_queue(args):
    if args.queue_cmd == "list":
        _queue_list()
    elif args.queue_cmd == "create":
        _queue_create(args)
    elif args.queue_cmd == "delete":
        _queue_delete(args)

def _queue_list():
    r = kubectl_global("get", "queues", "-o", "json")
    items = json.loads(r.stdout).get("items", [])
    if not items:
        print("No queues found.")
        return
    rows = []
    for q in items:
        meta   = q["metadata"]
        spec   = q.get("spec", {})
        parent = spec.get("parentQueue", "—")
        prio   = spec.get("priority", "—")
        res    = spec.get("resources", {})
        quota  = res.get("gpu", {}).get("quota", "—")
        nodes  = QUEUE_NODES.get(meta["name"])
        node   = ",".join(nodes) if nodes else "—"
        rows.append((meta["name"], parent, str(prio), str(quota), node))
    _print_table(("NAME", "PARENT", "PRIORITY", "GPU-QUOTA", "NODE"), rows)

def _queue_create(args):
    if ROLE not in ("lab-manager", None) and ROLE != "admin":
        _die("Only lab-managers can create queues.")
    parent = args.parent or PARENT_QUEUE
    if not parent:
        _die("--parent required (or set parent_queue in config file)")
    manifest = {
        "apiVersion": "scheduling.run.ai/v2",
        "kind": "Queue",
        "metadata": {"name": args.name},
        "spec": {
            "parentQueue": parent,
            "priority": args.priority,
            "resources": {
                "gpu":    {"quota": args.quota, "limit": -1, "overQuotaWeight": 1},
                "cpu":    {"quota": -1,          "limit": -1, "overQuotaWeight": 1},
                "memory": {"quota": -1,          "limit": -1, "overQuotaWeight": 1},
            },
        },
    }
    kubectl_global("apply", "-f", "-", stdin_data=json.dumps(manifest))
    msg = f"queue/{args.name} created  [parent: {parent}  priority: {args.priority}  gpu-quota: {args.quota}]"
    if args.node:
        _config_update_queue_node(args.name, args.node)
        node_str = ",".join(args.node)
        msg += f"  node:{node_str}"
        print(msg)
        print(f"  → node selector saved to ~/.kai/config.yaml")
        print(f"  → Re-run 'kai push-config' for existing users to distribute")
    else:
        print(msg)

def _queue_delete(args):
    if ROLE not in ("lab-manager", None) and ROLE != "admin":
        _die("Only lab-managers can delete queues.")
    kubectl_global("delete", "queue", args.name)
    if args.name in QUEUE_NODES:
        _config_update_queue_node(args.name, None)  # None = remove
        print(f"queue/{args.name} deleted  (node selector removed from config)")
    else:
        print(f"queue/{args.name} deleted")

# ── utilities ──────────────────────────────────────────────────────────────────

def _fmt_age(ts):
    if not ts:
        return "—"
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        s  = int((datetime.now(timezone.utc) - dt).total_seconds())
        if s < 60:     return f"{s}s"
        if s < 3600:   return f"{s // 60}m"
        if s < 86400:  return f"{s // 3600}h"
        return f"{s // 86400}d"
    except Exception:
        return "—"

def _print_table(headers, rows, footer=None):
    all_rows = [headers] + rows + ([footer] if footer else [])
    col_w    = [max(len(str(r[i])) for r in all_rows) for i in range(len(headers))]
    sep      = "  ".join("─" * w for w in col_w)

    print("  ".join(str(h).ljust(col_w[i]) for i, h in enumerate(headers)))
    print(sep)
    for row in rows:
        print("  ".join(str(v).ljust(col_w[i]) for i, v in enumerate(row)))
    if footer:
        print(sep)
        print("  ".join(str(v).ljust(col_w[i]) for i, v in enumerate(footer)))

def _die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)

