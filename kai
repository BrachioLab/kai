# ── kubectl helpers ────────────────────────────────────────────────────────────

def kubectl(*args, capture=True, check=True, stdin_data=None):
    cmd = ["kubectl", "--kubeconfig", KUBECONFIG, "--namespace", NAMESPACE] + list(args)
    if capture:
        result = subprocess.run(
            cmd, capture_output=True, text=True, check=False,
            input=stdin_data,
        )
        if check and result.returncode != 0:
            print(result.stderr.strip(), file=sys.stderr)
            sys.exit(result.returncode)
        return result
    else:
        subprocess.run(cmd, check=False, input=stdin_data, text=bool(stdin_data))
        return None

def kubectl_global(*args, capture=True, check=True, stdin_data=None):
    """kubectl without --namespace, for cluster-scoped resources (e.g. Queue CRDs)."""
    cmd = ["kubectl", "--kubeconfig", KUBECONFIG] + list(args)
    if capture:
        result = subprocess.run(
            cmd, capture_output=True, text=True, check=False,
            input=stdin_data,
        )
        if check and result.returncode != 0:
            print(result.stderr.strip(), file=sys.stderr)
            sys.exit(result.returncode)
        return result
    else:
        subprocess.run(cmd, check=False, input=stdin_data, text=bool(stdin_data))
        return None

# ── Manifest builder ───────────────────────────────────────────────────────────

def _unique_name(prefix="job"):
    return f"{prefix}-{uuid.uuid4().hex[:6]}"

def _build_resources(gpu_count, cpu_req, mem_req):
    if gpu_count > 0:
        cpu_req  = cpu_req  or f"{gpu_count * 4}"
        mem_req  = mem_req  or f"{gpu_count * 32}Gi"
    else:
        cpu_req  = cpu_req  or "2"
        mem_req  = mem_req  or "4Gi"

    resources = {"requests": {"cpu": cpu_req, "memory": mem_req}}
    if gpu_count > 0:
        resources["limits"] = {"nvidia.com/gpu": str(gpu_count)}
    return resources

def _build_manifest(*, name, image, command, gpu_count, cpu_req, mem_req,
                    queue, node_selector, node_affinity, backoff_limit, envs,
                    interactive, volumes, ports, workdir, large_shm, attach,
                    host_network=False, priority=None):
    pod_labels = {
        "kai.scheduler/queue": queue,
        "kai.scheduler/user":  os.environ.get("USER", "unknown"),
        "priorityClassName":   priority or _DEFAULT_PRIORITY,
    }

    container = {
        "name":      "work",
        "image":     image,
        "resources": _build_resources(gpu_count, cpu_req, mem_req),
    }

    if interactive:
        container["command"] = ["sleep", "infinity"]
    elif command:
        if command[0].startswith("-"):
            # Flags-only command: pass as args to the image's existing entrypoint
            container["args"] = command
        else:
            container["command"] = command[:1]
            if len(command) > 1:
                container["args"] = command[1:]

    if envs:
        container["env"] = [{"name": k, "value": v} for k, v in envs.items()]

    if workdir:
        container["workingDir"] = workdir

    if ports:
        container["ports"] = [{"containerPort": int(p)} for p in ports]

    # --attach: keep stdin and tty open so kubectl attach -it works
    if attach:
        container["stdin"] = True
        container["tty"]   = True

    # Build hostPath volumes from --volume HOST:CONTAINER[:ro]
    vol_defs   = []
    vol_mounts = []
    for i, vol in enumerate(volumes or []):
        parts     = vol.split(":")
        if len(parts) < 2:
            _die(f"Invalid --volume '{vol}': expected HOST_PATH:CONTAINER_PATH[:ro]")
        host_path   = parts[0]
        mount_path  = parts[1]
        read_only   = len(parts) > 2 and parts[2] == "ro"
        vol_name    = f"vol{i}"
        vol_defs.append({"name": vol_name, "hostPath": {"path": host_path}})
        mount = {"name": vol_name, "mountPath": mount_path}
        if read_only:
            mount["readOnly"] = True
        vol_mounts.append(mount)

    # --large-shm: replace /dev/shm with an in-memory emptyDir (no size cap)
    if large_shm:
        vol_defs.append({"name": "dshm", "emptyDir": {"medium": "Memory"}})
        vol_mounts.append({"name": "dshm", "mountPath": "/dev/shm"})

    if vol_mounts:
        container["volumeMounts"] = vol_mounts

    pod_spec = {
        "schedulerName": "kai-scheduler",
        "restartPolicy": "Never",
        "containers":    [container],
    }
    if host_network:
        pod_spec["hostNetwork"] = True
        pod_spec["dnsPolicy"] = "ClusterFirstWithHostNet"
    if node_selector:
        pod_spec["nodeSelector"] = node_selector
    if node_affinity:
        pod_spec["affinity"] = {"nodeAffinity": {"requiredDuringSchedulingIgnoredDuringExecution": {
            "nodeSelectorTerms": [{"matchExpressions": [{
                "key": "kubernetes.io/hostname",
                "operator": "In",
                "values": node_affinity,
            }]}]
        }}}
    if vol_defs:
        pod_spec["volumes"] = vol_defs

    if interactive:
        return {
            "apiVersion": "v1",
            "kind":       "Pod",
            "metadata":   {"name": name, "namespace": NAMESPACE, "labels": pod_labels},
            "spec":       pod_spec,
        }
    else:
        return {
            "apiVersion": "batch/v1",
            "kind":       "Job",
            "metadata":   {"name": name, "namespace": NAMESPACE},
            "spec": {
                "backoffLimit": backoff_limit,
                "template": {
                    "metadata": {"labels": pod_labels},
                    "spec":     pod_spec,
                },
            },
        }

# ── submit ─────────────────────────────────────────────────────────────────────

def cmd_submit(args):
    # Load job file and merge; CLI args take precedence over file values
    if args.file:
        with open(args.file) as _f:
            _job = yaml.safe_load(_f) or {}
        if not args.image:
            args.image = _job.get("image") or _die("job file missing 'image'")
        if not args.name:
            args.name = _job.get("name")
        if args.gpu == 0 and _job.get("gpu"):
            args.gpu = int(_job["gpu"])
        if not args.cpu:
            args.cpu = _job.get("cpu")
        if not args.memory:
            args.memory = _job.get("memory")
        if not args.queue:
            args.queue = _job.get("queue")
        if not args.node:
            args.node = _job.get("node")
        if not args.gpu_type:
            args.gpu_type = _job.get("gpu_type")
        if not args.workdir:
            args.workdir = _job.get("workdir")
        if not args.large_shm:
            args.large_shm = bool(_job.get("large_shm", False))
        if not args.interactive:
            args.interactive = bool(_job.get("interactive", False))
        if not args.attach:
            args.attach = bool(_job.get("attach", False))
        if args.backoff_limit is None and "backoff_limit" in _job:
            args.backoff_limit = int(_job["backoff_limit"])
        # Env: file provides a dict; CLI --env list is appended on top
        _file_env = _job.get("env") or {}
        _cli_env = list(args.env or [])
        _cli_keys = {e.split("=", 1)[0] for e in _cli_env if "=" in e}
        args.env = [f"{k}={v}" for k, v in _file_env.items() if k not in _cli_keys] + _cli_env
        # Volumes, ports: file provides lists; CLI appends on top
        args.volume = list(_job.get("volumes") or []) + list(args.volume or [])
        args.port = [str(p) for p in (_job.get("ports") or [])] + list(args.port or [])
        if not args.forward:
            args.forward = bool(_job.get("forward", False))
        if not args.host_network:
            args.host_network = bool(_job.get("host_network", False))
        if not args.priority:
            args.priority = _job.get("priority") or None
        # Command: file wins if CLI has none
        if not args.command:
            _cmd = _job.get("command")
            if isinstance(_cmd, str):
                import shlex
                args.command = shlex.split(_cmd)
            elif isinstance(_cmd, list):
                args.command = [str(c) for c in _cmd]

    if not args.image:
        _die("--image is required (or set 'image' in the job file)")

    name = args.name or _unique_name()

    # Enforce allowed_queues from config file
    if ALLOWED_QUEUES is not None and args.queue not in ALLOWED_QUEUES:
        _die(f"Queue '{args.queue}' is not in your allowed queues: {', '.join(ALLOWED_QUEUES)}")

    # Validate priority class
    if args.priority and args.priority not in PRIORITY_CLASSES:
        _die(f"Unknown priority '{args.priority}'. Choose from: {', '.join(sorted(PRIORITY_CLASSES))}")

    # Resolve node placement
    node_selector = {}
    node_affinity = None
    if args.node:
        node_selector["kubernetes.io/hostname"] = args.node
    elif QUEUE_NODES.get(args.queue):
        nodes = QUEUE_NODES[args.queue]
        if len(nodes) == 1:
            node_selector["kubernetes.io/hostname"] = nodes[0]
        else:
            node_affinity = nodes
    if args.gpu_type:
        label = GPU_TYPE_MAP.get(args.gpu_type.lower())
        if not label:
            _die(f"Unknown GPU type '{args.gpu_type}'. Valid: {', '.join(GPU_TYPE_MAP)}")
        node_selector["nvidia.com/gpu.product"] = label

    # Parse --env KEY=VALUE
    envs = {}
    for e in args.env or []:
        if "=" not in e:
            _die(f"Invalid --env '{e}': expected KEY=VALUE")
        k, v = e.split("=", 1)
        envs[k] = v

    # backoffLimit default: preemptible jobs retry after eviction; guaranteed queues fail fast
    if args.backoff_limit is not None:
        backoff = args.backoff_limit
    else:
        backoff = 10 if args.queue in ("preemptible", "default") else 0

    manifest = _build_manifest(
        name=name,
        image=args.image,
        command=args.command or [],
        gpu_count=args.gpu,
        cpu_req=args.cpu,
        mem_req=args.memory,
        queue=args.queue,
        node_selector=node_selector,
        node_affinity=node_affinity,
        backoff_limit=backoff,
        envs=envs,
        interactive=args.interactive,
        volumes=args.volume or [],
        ports=args.port or [],
        workdir=args.workdir,
        large_shm=args.large_shm,
        attach=args.attach,
        host_network=args.host_network,
        priority=args.priority,
    )

    kubectl("apply", "-f", "-", capture=True, stdin_data=json.dumps(manifest))

    if args.interactive:
        print(f"Waiting for pod {name} to be ready...")
        _wait_for_pod(name)
        print(f"Connected to {name}  (exit or Ctrl-D to quit)\n")
        kubectl("exec", "-it", name, "--", "bash", capture=False)
        answer = input(f"\nDelete pod '{name}'? [Y/n] ").strip().lower()
        if answer in ("", "y", "yes"):
            kubectl("delete", "pod", name, capture=True)
            print(f"Deleted pod {name}.")
    elif args.attach:
        print(f"Waiting for job {name} to start...")
        pod = _wait_for_job_pod(name)
        print(f"Attaching to {pod}  (exit shell or Ctrl-P Ctrl-Q to detach)\n")
        kubectl("attach", "-it", pod, capture=False)
        print(f"\nJob '{name}' still exists. To remove: kai delete {name}")
    elif args.forward:
        if not args.port:
            _die("--forward requires at least one --port declaration")
        mappings = [f"{p}:{p}" if ":" not in str(p) else str(p) for p in args.port]
        # Kill any process holding the local ports, then wait for sockets to close
        for m in mappings:
            local_port = m.split(":")[0]
            r = subprocess.run(
                ["ss", "-Hlntp", f"sport = :{local_port}"],
                capture_output=True, text=True)
            for pid in set(re.findall(r"pid=(\d+)", r.stdout)):
                subprocess.run(["kill", "-9", pid], capture_output=True)
        time.sleep(1)
        print(f"Waiting for job {name} to start...")
        pod = _wait_for_job_pod(name, timeout=600)
        print(f"Forwarding {', '.join(mappings)}  (Ctrl-C to stop)\n")
        kubectl("port-forward", f"pod/{pod}", *mappings, capture=False, check=False)
        print(f"\nJob '{name}' still exists. To remove: kai delete {name}")
    else:
        gpu_str = f"{args.gpu} GPU{'s' if args.gpu != 1 else ''}" if args.gpu else "CPU only"
        print(f"Submitted {name}  [{args.queue}] [{gpu_str}]")
        print(f"  kai logs {name} -f    # stream logs")
        print(f"  kai delete {name}     # cancel")

def _wait_for_pod(name, timeout=120):
    """Wait for a Pod (by pod name) to be Running — used by --interactive mode."""
    deadline = time.time() + timeout
    dots = 0
    while time.time() < deadline:
        r = kubectl("get", "pod", name, "-o", "jsonpath={.status.phase}",
                    capture=True, check=False)
        phase = r.stdout.strip()
        if phase == "Running":
            return
        if phase in ("Failed", "Succeeded"):
            _die(f"Pod {name} entered phase '{phase}' before interactive session could start.")
        print("." * (dots % 4 + 1), end="\r", flush=True)
        dots += 1
        time.sleep(2)
    _die(f"Timed out waiting for pod {name} to start.")

def _wait_for_job_pod(job_name, timeout=120):
    """Wait for a Job's pod to be Running; return the pod name — used by --attach mode."""
    deadline = time.time() + timeout
    dots = 0
    while time.time() < deadline:
        r = kubectl("get", "pods", "-l", f"job-name={job_name}",
                    "-o", "jsonpath={.items[0].status.phase} {.items[0].metadata.name}",
                    capture=True, check=False)
        parts = r.stdout.strip().split()
        if len(parts) == 2:
            phase, pod_name = parts
            if phase == "Running":
                return pod_name
            if phase in ("Failed", "Succeeded"):
                _die(f"Pod for job {job_name} entered phase '{phase}' before attach could start.")
        print("." * (dots % 4 + 1), end="\r", flush=True)
        dots += 1
        time.sleep(2)
    _die(f"Timed out waiting for job {job_name} pod to start.")

